{
  "name": "github-actions-demo",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@vitejs/plugin-react": "^5.1.2",
    "jsdom": "^27.3.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.15"
  },
  "homepage": "https://saleemadnan.github.io/github-actions-demo",
  "scripts": {
    "start": "vite --host 127.0.0.1",
